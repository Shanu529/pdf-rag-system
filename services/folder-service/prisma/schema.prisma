generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Folder {

  id        String   @id @default(cuid())

  name      String

  userId    String

  createdAt DateTime @default(now())

}