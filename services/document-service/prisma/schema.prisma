generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {

  id        String   @id @default(cuid())

  fileName  String

  docId     String

  createdAt DateTime @default(now())

  folderId  String

  summary   String?
  
  status    String  @default("PROCESSING")

}